# ══════════════════════════════════════════════════════════════════════════════
#  Santoral Bot — Variables de entorno
#  Copia este archivo a .env y rellena cada valor
#  NUNCA subas .env al repositorio
# ══════════════════════════════════════════════════════════════════════════════

# ─── Google AI — Gemini 1.5 Pro ───────────────────────────────────────────────
# Obtener en: aistudio.google.com → API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OpenAI — DALL-E 3 ────────────────────────────────────────────────────────
# Obtener en: platform.openai.com → API Keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─── Google Cloud Text-to-Speech ──────────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs → Text-to-Speech API → Credentials
# Nota: no se usa actualmente en hosting compartido (sin vídeo), pero se reserva
# para cuando se migre a VPS con FFmpeg
GOOGLE_TTS_API_KEY=your_google_cloud_api_key_here
GOOGLE_TTS_VOICE=es-ES-Wavenet-B
GOOGLE_TTS_LANGUAGE=es-ES

# ─── Meta / Instagram Graph API ───────────────────────────────────────────────
# Ver guía completa en SETUP.md → sección "Configurar Instagram"
META_ACCESS_TOKEN=your_long_lived_page_access_token
META_INSTAGRAM_USER_ID=your_instagram_business_account_id

# ─── TikTok Content Posting API ───────────────────────────────────────────────
# Ver guía completa en SETUP.md → sección "Configurar TikTok"
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# ─── Rutas del sistema ────────────────────────────────────────────────────────
#
# STORAGE_BASE_PATH: donde el bot guarda imágenes, logs, etc.
#   → Puede estar fuera de public_html (recomendado por seguridad)
#   → Ejemplo Hostinger: /home/uXXXXXXX/santoral/storage
#
STORAGE_BASE_PATH=/home/uXXXXXXX/santoral/storage

#
# PUBLIC_MEDIA_PATH: directorio dentro de public_html
#   → Meta y TikTok necesitan descargar las imágenes vía HTTPS
#   → Ejemplo Hostinger: /home/uXXXXXXX/domains/tudominio.com/public_html/media
#   → Ejemplo si es el dominio principal: /home/uXXXXXXX/public_html/media
#
PUBLIC_MEDIA_PATH=/home/uXXXXXXX/domains/tudominio.com/public_html/media

#
# PUBLIC_BASE_URL: URL pública que corresponde a PUBLIC_MEDIA_PATH
#   → Ejemplo: https://tudominio.com/media
#
PUBLIC_BASE_URL=https://tudominio.com/media

# ─── Assets ───────────────────────────────────────────────────────────────────
ASSETS_BASE_PATH=/home/uXXXXXXX/santoral/assets

# ─── FFmpeg (solo VPS, no disponible en hosting compartido) ───────────────────
FFMPEG_BIN=/usr/bin/ffmpeg

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info
TIMEZONE=Europe/Madrid

# Nombre de tu cuenta en redes (aparece en las imágenes)
SOCIAL_HANDLE=@tusantoral
